#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{

    int n,k;
    cin>>n>>k;

    ll x;
    ll mn=LLONG_MAX;
    int cnt=0;

    for(int i=0;i<n;i++)
    {
        cin>>x;
        mn=min(mn,x);
        cnt++;

        if(cnt==k)
        {
            cout<<mn<<" ";
            mn=LLONG_MAX;
            cnt=0;
        }
    }

    if(cnt>0)
    {
        cout<<mn<<" ";
    }


}
