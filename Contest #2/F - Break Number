#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{
    int n;
    cin>>n;

    ll x;
    int ans=0;

    for(int i=0;i<n;i++)
    {
        cin>>x;
        int cnt=0;

        while(x%2==0)
        {
            x/=2;
            cnt++;
        }

        ans=max(ans,cnt);
    }

    cout<<ans<<nl;

}
