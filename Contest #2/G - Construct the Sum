#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{
   int t;
   cin>>t;
   while(t--)
   {
 
        ll n,s;
        cin>>n>>s;
        
        ll mx=n*(n+1)/2;
        
        if(s>mx)
        {
            cout<<-1<<nl;
            continue;
        }
 
        for(ll i=n;i>=1;i--)
        {
            if(i<=s)
            {
                cout<<i<<" ";
                s-=i;
            }
        }
        cout<<nl;
 
 
 
 
 
 
   }

}
