#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;
using vll = vector<long long>;

int main()
{

    int n;
    cin>>n;

    vi a(n);
    for(int i=0;i<n;i++)
    {
        cin>>a[i];
    }


    vi res;
    for(int i=0;i<n;i++)
    {
        if(a[i]==0)
        {
            reverse(res.begin(),res.end());
        }
        res.push_back(a[i]);
    }

    for(int x:res)
    {
        cout<<x<<" ";
    }






}
