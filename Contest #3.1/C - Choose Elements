#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;
using vll = vector<long long>;

int main()
{

    int n,k;
    cin>>n>>k;

    vi a(n);
    for(int i=0;i<n;i++)
    {
        cin>>a[i];
    }

    sort(a.begin(),a.end());

    ll sum=0;
    int cnt=0;

    for(int i=n-1;i>=0 && cnt<k;i--)
    {
        if(a[i]>0)
        {
            sum+=a[i];
            cnt++;
        }
        else
        {
            break;
        }

    }

    cout<<sum;









}
