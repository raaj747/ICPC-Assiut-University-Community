#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;
using vll = vector<long long>;

int main()
{

    int n;
    cin>>n;

    vi a(n);
    for(int i=0;i<n;i++)
    {
        cin>>a[i];
    }

    int cnt=0;
    for(int i=0;i<n;i++)
    {
        for(int j=0;j<n;j++)
        {
            if(a[j]==a[i]+1)
            {
                cnt++;
                break;
            }
        }
    }

    cout<<cnt;









}
