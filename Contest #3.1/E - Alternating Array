    vi a(n);
    for(int i=0;i<n;i++)
    {
        cin>>a[i];
    }

    int op1=0;
    int op2=0;

    for(int i=0;i<n;i++)
    {

        if(i%2==0 && a[i]<0)
        {
            op1++;
        }
