#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;
using vll = vector<long long>;

int main()
{

    int n;
    cin>>n;

    vll a(n);
    for(int i=0;i<n;i++)
    {
        cin>>a[i];
    }

    int left=0;
    int right=n-1;

    while(left<=right)
    {
        if(left==right)
        {
            cout<<a[left]<<" ";
            break;
        }

        cout<<a[left]<<" "<<a[right]<<" ";
        left++;
        right--;




    }









}
