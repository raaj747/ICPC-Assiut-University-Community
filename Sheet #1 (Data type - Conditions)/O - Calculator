#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{

    int a,b;
    char op;
    cin>>a>>op>>b;

    if(op=='+')
    {
        cout<<a+b<<nl;
    }
    else if(op=='-')
    {
        cout<<a-b<<nl;
    }
    else if(op=='*')
    {
        cout<<a*b<<nl;
    }
    else if(op=='/')
    {
        cout<<a/b<<nl;
    }




}
