#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{

    int n;
    cin>>n;

    int even=0, odd=0, pos=0, neg=0;

    int x;
    for(int i=0;i<n;i++)
    {
        cin>>x;

        if(x%2==0)
        {
            even++;
        }
        else
        {
            odd++;
        }

        if(x>0)
        {
            pos++;
        }
        else if(x < 0)
        {
            neg++;
        }

    }

    cout<<"Even: "<<even<<nl;
    cout<<"Odd: "<<odd<<nl;
    cout<<"Positive: "<<pos<<nl;
    cout<<"Negative: "<<neg<<nl;



}
