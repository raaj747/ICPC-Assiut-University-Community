#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{

    int t;
    cin>>t;
    while(t--)
    {
        int x,y;
        cin>>x>>y;

        int s=0;
        if(x>y)
        {
            int temp=x;
            x=y;
            y=temp;
        }

        for(int i=x+1;i<y;i++)
        {
            if(i%2!=0)
            {
                s+=i;
            }
        }

        cout<<s<<nl;


    }



}
