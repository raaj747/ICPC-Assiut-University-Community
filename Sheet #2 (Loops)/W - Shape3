#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{

    int n;
    cin>>n;

    for(int i=1;i<=n;i++)
    {
        for(int s=1;s<=n-i;s++)
        {
            cout<<" ";
        }
        for(int j=1;j<=2*i-1;j++)
        {
            cout << "*";
        }
        cout<<nl;

    }

    for(int i=n;i>=1;i--)
    {
        for(int s=1;s<=n-i;s++)
        {
            cout << " ";
        }
        for(int j=1;j<=2*i-1;j++)
        {
            cout << "*";
        }
        cout<<nl;
    }



}
