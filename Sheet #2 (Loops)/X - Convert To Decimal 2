#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{

    int t;
    cin>>t;
    while(t--)
    {
        ll n;
        cin>>n;

        int cnt=0;
        while(n>0)
        {
            if(n%2==1)
                cnt++;
            n/=2;
        }

        ll ans=0;
        for(int i=0;i<cnt;i++)
        {
           ans=ans*2+1;
        }

        cout<<ans<<nl;
    }



}
