#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{

    int n;
    cin>>n;

    ll a=0;
    ll b=1;

    for(int i=1;i<=n;i++)
    {
        if(i==1)
        {
            cout<<a<<" ";
        }
        else if(i==2)
        {
            cout<<b<<" ";
        }
        else
        {
            ll c=a+b;
            cout<<c<<" ";
            a=b;
            b=c;
        }
    }

    cout<<endl;



}
