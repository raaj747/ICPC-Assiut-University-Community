#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{

    int n;
    cin>>n;

    int a[1000];

    for(int i=0;i<n;i++)
    {
        cin>>a[i];
    }

    int mn=a[0];
    int pos=1;

    for(int i=1;i<n;i++)
    {
        if(a[i]<mn)
        {
            mn=a[i];
            pos=i+1;
        }
    }

    cout<<mn<<" "<<pos;

}
