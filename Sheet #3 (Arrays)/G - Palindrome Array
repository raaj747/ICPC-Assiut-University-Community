#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{

    int n;
    cin>>n;
    ll a[100000];

    for(int i=0;i<n;i++)
    {
        cin>>a[i];
    }

    bool palindrome=true;
    for(int i=0;i<n/2;i++)
    {
        if(a[i]!=a[n-1-i])
        {
            palindrome=false;
            break;
        }
    }

    if(palindrome)
    {
        cout << "YES";
    }
    else
    {
        cout << "NO";
    }



}
