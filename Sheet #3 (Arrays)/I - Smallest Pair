using vi = vector<int>;

int main()
{

    int t;
    cin>>t;
    while(t--)
    {
        int n;
        cin>>n;
        int a[100];

        for(int i=0;i<n;i++)
        {
            cin>>a[i];
        }

        int b=INT_MAX;
        int c=a[0]-0;

        for(int i=1;i<n;i++)
        {
            int d=a[i]+i+c;
            if(d<b)
