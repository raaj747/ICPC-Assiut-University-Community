#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{

    int n;
    cin>>n;

    int a[1000];

    for(int i=0;i<n;i++)
    {
        cin>>a[i];
    }

    int b=a[0];
    int c=1;

    for(int i=1;i<n;i++)
    {
        if(a[i]<b)
        {
            b=a[i];
            c=1;
        }
        else if(a[i]==b)
        {
            c++;
        }
    }

    if(c%2==1)
    {
        cout<<"Lucky";
    }
    else
    {
        cout<<"Unlucky";
    }



}
