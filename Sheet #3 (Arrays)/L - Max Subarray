#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{

    int t;
    cin>>t;
    while(t--)
    {
        int n;
        cin>>n;

        int a[100];

        for(int i=0;i<n;i++)
        {
            cin>>a[i];
        }

        for(int i=0;i<n;i++)
        {
            int m=a[i];
            for(int j=i;j<n;j++)
            {
                if(a[j]>m)
                    m=a[j];
                cout<<m<<" ";
            }
        }
        cout<<nl;
    }



}
