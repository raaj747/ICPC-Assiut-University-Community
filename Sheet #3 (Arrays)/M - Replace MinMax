#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{

    int n;
    cin>>n;

    int a[1000];

    for(int i=0;i<n;i++)
    {
        cin>>a[i];
    }

    int b=0;
    int c=0;

    for(int i=1;i<n;i++)
    {
        if(a[i]<a[b])
        {
            b=i;
        }
        if(a[i]>a[c])
        {
            c=i;
        }

    }

    int t=a[b];
    a[b]=a[c];
    a[c]=t;

    for(int i=0;i<n;i++)
    {
        cout<<a[i]<<" ";
    }



}
