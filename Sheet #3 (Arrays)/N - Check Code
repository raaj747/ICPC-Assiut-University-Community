#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{

    int a,b;
    string s;
    cin>>a>>b>>s;

    bool ok=true;

    if(s[a]!='-')
    {
        ok=false;
    }

    for(int i=0;i<s.size();i++)
    {
        if(i==a)
         continue;
        if(s[i]<'0' || s[i]>'9')
        {
            ok=false;
            break;
        }
    }

    if(ok)
    {
        cout<<"Yes";
    }
    else
    {
        cout<<"No";
    }



}
