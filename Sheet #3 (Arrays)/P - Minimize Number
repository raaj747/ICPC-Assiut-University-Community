#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{

    int n;
    cin>>n;

    int a[200];

    for(int i=0;i<n;i++)
    {
        cin>>a[i];
    }

    int b=0;

    while(true)
    {
        bool even=true;
        for(int i=0;i<n;i++)
        {
            if(a[i]%2!=0)
            {
                even=false;
                break;
            }
        }

        if(!even)
            break;
        for(int i=0;i<n;i++)
            a[i]/=2;
        b++;
    }

    cout<<b;



}
