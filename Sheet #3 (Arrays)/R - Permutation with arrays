#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{

    int n;
    cin>>n;

    int a[1000],b[1000];

    for(int i=0;i<n;i++)
    {
        cin>>a[i];
    }

    for(int i=0;i<n;i++)
    {
        cin>>b[i];
    }

    bool ok=true;

    for(int i=0;i<n;i++)
    {
        bool found=false;
        for(int j=0;j<n;j++)
        {
            if(b[i]==a[j])
            {
                a[j]=-1;
                found=true;
                break;
            }
        }
        if(!found)
        {
            ok=false;
            break;
        }
    }

    if(ok)
    {
        cout<<"yes";
    }
    else
    {
        cout<<"no";
    }



}
