#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{

    int n;
    cin>>n;

    int a[100][100];

    for(int i=0;i<n;i++)
    {
        for(int j=0;j<n;j++)
        {
            cin>>a[i][j];
        }
    }

    int b=0,c=0;

    for(int i=0;i<n;i++)
    {
        b+=a[i][i];
        c+=a[i][n-1-i];
    }

    int ans=abs(b - c);

    cout<<ans;



}
