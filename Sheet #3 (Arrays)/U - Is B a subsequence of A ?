#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{

    int n,m;
    cin>>n>>m;

    int a[10000],b[10000];

    for(int i=0;i<n;i++)
    {
        cin>>a[i];
    }

    for(int i=0;i<m;i++)
    {
        cin>>b[i];
    }

    int i=0,j=0;

    while(i<n && j<m)
    {
        if(a[i]==b[j])
            j++;
        i++;
    }

    if(j==m)
    {
        cout<<"YES";
    }
    else
    {
        cout<<"NO";
    }



}
