#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{

    int n,m;
    cin>>n>>m;

    char a[100][100];

    for(int i=0;i<n;i++)
    {
        for(int j=0;j<m;j++)
        {
            cin>>a[i][j];
        }
    }

    int x,y;
    cin>>x>>y;
    x--;
    y--;

    bool all_x=true;

    for(int i=x-1;i<=x+1;i++)
    {
        for(int j=y-1;j<=y+1;j++)
        {
            if(i==x && j==y)
                continue;
            if(i>=0 && i<n && j>=0 && j<m)
            {
                if(a[i][j]!='x')
                {
                    all_x=false;
                    break;
                }
            }
        }
        if(!all_x)
            break;
    }

    if(all_x)
    {
        cout<<"yes";
    }
    else
    {
        cout<<"no";
    }




}
