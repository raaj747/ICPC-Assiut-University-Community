#include<bits/stdc++.h>
using namespace std;

typedef long long ll;
const char nl='\n';
using vi = vector<int>;

int main()
{

    int n,q;
    cin>>n>>q;

    vector<ll> a(n+1,0);
    ll c;

    for(int i=1;i<=n;i++)
    {
        cin>>c;
        a[i]=a[i-1]+c;
    }

    for(int i=0;i<q;i++)
    {
        int l,r;
        cin>>l>>r;

        int ans=a[r]-a[l-1];
        cout<<ans<<nl;
    }




}
